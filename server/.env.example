# ============================================================================
# Yüz Tanıma SaaS — server environment variables
# Copy this file to `server/.env` and fill in real values for local development.
# NEVER commit the real `.env` — it is in .gitignore.
# ============================================================================

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=dev-secret-change-me-in-production
HOST=0.0.0.0
PORT=5000

# --- Domain ---
BASE_DOMAIN=yuztanima.com
SUPER_ADMIN_SUBDOMAIN=admin

# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/yuz_tanima_dev
TEST_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/yuz_tanima_test

# --- Redis (Celery + Socket.IO + rate limit) ---
REDIS_URL=redis://localhost:6379/0

# --- Biometric encryption key ---
# Generate via:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FACE_ENCRYPTION_KEY=

# --- Object storage (S3 / MinIO) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=yuz-tanima
S3_REGION=eu-central-1

# --- KVKK retention ---
SNAPSHOT_RETENTION_DAYS=30
ACCESS_LOG_RETENTION_DAYS=365

# --- Logging / Observability ---
LOG_LEVEL=INFO
SENTRY_DSN=